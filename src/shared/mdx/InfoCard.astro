---
interface Props {
  title: string
  icon?: string
}

const { title, icon = '📘' } = Astro.props
---

<div class='rounded-xl border border-slate-200 bg-white p-5'>
  <div class='flex items-center gap-2'>
    <span>{icon}</span>
    <h3 class='font-semibold text-slate-900'>
      {title}
    </h3>
  </div>

  <div class='my-4 border-t border-slate-100'></div>

  <slot />
</div>
